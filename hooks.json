{
  "safety-gate": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/safety-gate.js"
          }
        ]
      }
    ]
  },
  "compaction-reminder": {
    "enabled": true,
    "PreInvocation": [
      {
        "type": "command",
        "command": "node scripts/pre-invocation-reminder.js"
      }
    ]
  }
}
